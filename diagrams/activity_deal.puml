@startuml activity_deal
title Диаграмма деятельности — CRUD Сделки

start
:Выбрать "Управление сделками";

switch (Выбор операции?)
case (Список)
    :Выполнить SELECT из PB_DEALS;
    :Отобразить таблицу сделок;
case (Добавить)
    :Ввести дату сделки;
    :Ввести название товара;
    :Ввести вид товара;
    :Ввести количество;
    :Ввести ID маклера;
    :Ввести фирму-покупателя;
    :INSERT в PB_DEALS;
    if (Успешно?) then (да)
        :Обновить статистику маклера\n(fn_update_broker_stats);
        :Сообщение: "Сделка добавлена";
    else (нет)
        :Сообщение об ошибке;
    endif
case (Обновить)
    :Ввести ID сделки;
    :Ввести новые данные;
    :UPDATE PB_DEALS;
    :Сообщение о результате;
case (Удалить)
    :Ввести ID сделки;
    :DELETE FROM PB_DEALS;
    :Сообщение о результате;
case (Назад)
endswitch

stop
@enduml
