@startuml sequence_login
title Диаграмма последовательности — Аутентификация

actor "Пользователь" as User
participant "main.c" as Main
participant "auth.c" as Auth
database "SQLite\nPB_USERS" as DB

User -> Main : Ввод логина и пароля
Main -> Auth : auth_login(db, username, password, &user)
Auth -> Auth : hash_password(password)
Auth -> DB : SELECT * FROM PB_USERS\nWHERE username = ?
DB --> Auth : Запись пользователя
Auth -> Auth : Сравнить хэши

alt Хэши совпадают
    Auth --> Main : return 0 (успех)
    Main --> User : "Добро пожаловать!\nРоль: admin/broker"
    alt role = admin
        Main -> Main : admin_menu(db)
    else role = broker
        Main -> Main : broker_menu(db, broker_id)
    end
else Хэши не совпадают
    Auth --> Main : return -1 (ошибка)
    Main --> User : "Ошибка аутентификации"
end

@enduml
