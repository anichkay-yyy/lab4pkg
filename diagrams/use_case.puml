@startuml use_case
title Диаграмма вариантов использования — Парфюмерный базар

left to right direction

actor "Администратор" as Admin
actor "Маклер" as Broker

rectangle "Парфюмерный базар" {
    usecase "Войти в систему" as UC_Login
    usecase "Управление маклерами" as UC_Brokers
    usecase "Добавить маклера" as UC_AddBroker
    usecase "Редактировать маклера" as UC_EditBroker
    usecase "Удалить маклера" as UC_DelBroker
    usecase "Управление товарами" as UC_Goods
    usecase "Добавить товар" as UC_AddGoods
    usecase "Редактировать товар" as UC_EditGoods
    usecase "Удалить товар" as UC_DelGoods
    usecase "Управление сделками" as UC_Deals
    usecase "Добавить сделку" as UC_AddDeal
    usecase "Редактировать сделку" as UC_EditDeal
    usecase "Удалить сделку" as UC_DelDeal
    usecase "Просмотр отчетов" as UC_Reports
    usecase "Продажи товара за период" as UC_R1
    usecase "Покупатели товара" as UC_R2
    usecase "Топ вид товара" as UC_R3
    usecase "Топ маклер" as UC_R4
    usecase "Маклеры по поставщикам" as UC_R5
    usecase "Обновить статистику маклера" as UC_Stats
    usecase "Консолидация товаров" as UC_Consolidate
    usecase "Сделки маклера на дату" as UC_DealsByDate
    usecase "Просмотр своих сделок" as UC_MyDeals
}

Admin --> UC_Login
Admin --> UC_Brokers
Admin --> UC_Goods
Admin --> UC_Deals
Admin --> UC_Reports
Admin --> UC_Stats
Admin --> UC_Consolidate
Admin --> UC_DealsByDate

Broker --> UC_Login
Broker --> UC_MyDeals
Broker --> UC_AddDeal
Broker --> UC_Reports
Broker --> UC_DealsByDate

UC_Brokers ..> UC_AddBroker : <<include>>
UC_Brokers ..> UC_EditBroker : <<include>>
UC_Brokers ..> UC_DelBroker : <<include>>

UC_Goods ..> UC_AddGoods : <<include>>
UC_Goods ..> UC_EditGoods : <<include>>
UC_Goods ..> UC_DelGoods : <<include>>

UC_Deals ..> UC_AddDeal : <<include>>
UC_Deals ..> UC_EditDeal : <<include>>
UC_Deals ..> UC_DelDeal : <<include>>

UC_Reports ..> UC_R1 : <<include>>
UC_Reports ..> UC_R2 : <<include>>
UC_Reports ..> UC_R3 : <<include>>
UC_Reports ..> UC_R4 : <<include>>
UC_Reports ..> UC_R5 : <<include>>

UC_AddDeal ..> UC_Stats : <<extend>>

@enduml
