@startuml component
title Диаграмма компонентов — Парфюмерный базар

package "Приложение (bin/perfume_bazaar)" {
    component [main.c\nТочка входа,\nменю, маршрутизация] as Main
    component [auth.c\nАутентификация,\nхэширование] as Auth
    component [broker.c\nCRUD маклеров] as BrokerMod
    component [goods.c\nCRUD товаров] as GoodsMod
    component [deal.c\nCRUD сделок] as DealMod
    component [queries.c\n5 аналитических\nзапросов] as Queries
    component [functions.c\n3 специальные\nфункции] as Functions
    component [db.c\nСоединение с БД,\nинициализация] as DB
}

package "Заголовочные файлы (includes/)" {
    component [db.h] as DBH
    component [auth.h] as AuthH
    component [broker.h] as BrokerH
    component [goods.h] as GoodsH
    component [deal.h] as DealH
    component [queries.h] as QueriesH
    component [functions.h] as FunctionsH
}

package "Тесты (tests/)" {
    component [test_db.c] as TDB
    component [test_auth.c] as TAuth
    component [test_broker.c] as TBroker
    component [test_goods.c] as TGoods
    component [test_deal.c] as TDeal
    component [test_queries.c] as TQueries
    component [test_functions.c] as TFunc
}

database "SQLite\nperfume_bazaar.db" as SQLite
component [sql/schema.sql\nСхема БД] as Schema

Main --> Auth
Main --> BrokerMod
Main --> GoodsMod
Main --> DealMod
Main --> Queries
Main --> Functions
Auth --> DB
BrokerMod --> DB
GoodsMod --> DB
DealMod --> DB
Queries --> DB
Functions --> DB
DB --> SQLite
Schema --> SQLite : init

TDB --> DB
TAuth --> Auth
TBroker --> BrokerMod
TGoods --> GoodsMod
TDeal --> DealMod
TQueries --> Queries
TFunc --> Functions

@enduml
